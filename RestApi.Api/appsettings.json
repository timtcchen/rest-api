{
  "AllowedHosts": "*",

  // ── Serilog 設定（雲端設計：結構化 JSON 輸出至 stdout，適合 Kubernetes/Docker/Azure Container Apps）
  // MinimumLevel.Override 可針對特定命名空間調整日誌層級，避免過多雜訊
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithEnvironmentName" ],
    "Properties": {
      "Application": "RestApi"
    }
  },

  // ── 資料庫連線字串（雲端環境請透過環境變數 ConnectionStrings__DefaultConnection 覆蓋）
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=restapi.db"
  },

  // JWT 設定
  // ⚠️ 生產環境安全建議：
  //   - SecretKey 至少 32 字元，並改用環境變數或 Azure Key Vault 管理，不應明文存放於此檔案。
  //   - Issuer / Audience 應設定為實際的服務 URL。
  "Jwt": {
    "Issuer": "https://your-api.com",
    "Audience": "https://your-api.com/resources",
    "SecretKey": "REPLACE-WITH-CRYPTOGRAPHICALLY-RANDOM-KEY-MIN-32-CHARS",
    "ExpiresInSeconds": 3600
  }
}
