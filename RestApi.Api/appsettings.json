{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // JWT 設定
  // ⚠️ 生產環境安全建議：
  //   - SecretKey 至少 32 字元，並改用環境變數或 Azure Key Vault 管理，不應明文存放於此檔案。
  //   - Issuer / Audience 應設定為實際的服務 URL。
  "Jwt": {
    "Issuer": "https://your-api.com",
    "Audience": "https://your-api.com/resources",
    "SecretKey": "REPLACE-WITH-CRYPTOGRAPHICALLY-RANDOM-KEY-MIN-32-CHARS",
    "ExpiresInSeconds": 3600
  },

  // OAuth 2.0 Client 設定（支援多個 Client，每個 Client 可設定不同的 scope）
  // ⚠️ 生產環境安全建議：
  //   - ClientSecret 應使用 bcrypt/Argon2 雜湊存入資料庫，不應明文寫在設定檔。
  //   - 此處僅供開發/測試環境示範使用。
  "OAuthClients": [
    {
      "ClientId": "service-a",
      "ClientSecret": "REPLACE-WITH-STRONG-SECRET-FOR-SERVICE-A",
      "Scopes": [ "read", "write" ]
    },
    {
      "ClientId": "service-b",
      "ClientSecret": "REPLACE-WITH-STRONG-SECRET-FOR-SERVICE-B",
      "Scopes": [ "read" ]
    }
  ]
}
