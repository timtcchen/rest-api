{
  // ── 開發環境設定（僅供本地開發/測試使用）──────────────────────────────────────
  // ⚠️ 不可將此檔案的真實 Secret 推送至版本控制系統
  // ⚠️ 生產環境請使用環境變數或 Azure Key Vault 管理以下敏感資訊

  // 開發環境覆蓋：改用易讀的文字格式輸出（而非 JSON），方便本地 debug
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },

  "ConnectionStrings": {
    "DefaultConnection": "Data Source=restapi-dev.db"
  },

  "Jwt": {
    "Issuer": "https://localhost:5001",
    "Audience": "https://localhost:5001/resources",
    "SecretKey": "dev-only-secret-key-replace-in-production-32+",
    "ExpiresInSeconds": 3600
  }
}
