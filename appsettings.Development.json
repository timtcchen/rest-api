{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // ── 開發環境設定（僅供本地開發/測試使用）──────────────────────────────────
  // ⚠️ 不可將此檔案的真實 Secret 推送至版本控制系統（已加入 .gitignore 建議）
  // ⚠️ 生產環境請使用環境變數或 Azure Key Vault 管理以下敏感資訊
  "Jwt": {
    "Issuer": "https://localhost:5001",
    "Audience": "https://localhost:5001/resources",
    "SecretKey": "dev-only-secret-key-replace-in-production-32+",
    "ExpiresInSeconds": 3600
  },

  "OAuthClients": [
    {
      "ClientId": "service-a",
      "ClientSecret": "dev-secret-service-a-replace-in-production",
      "Scopes": [ "read", "write" ]
    },
    {
      "ClientId": "service-b",
      "ClientSecret": "dev-secret-service-b-replace-in-production",
      "Scopes": [ "read" ]
    }
  ]
}
